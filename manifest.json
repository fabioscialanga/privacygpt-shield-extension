{
  "manifest_version": 3,
  "name": "PrivacyGPT Shield V3.3",
  "version": "3.3.0",
  "description": "Anonimizzazione privacy locale per ChatGPT con modalità semplice, legale, manuale/automatica e dizionario generico nomi comuni.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PrivacyGPT Shield V3.3",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "names.js",
        "rules.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "test.html",
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png",
        "test.js",
        "names.js",
        "rules.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}